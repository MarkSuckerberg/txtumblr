{
	"name": "txtumblr",
	"description": "API to retrieve better formatted embeds for tumblr posts",
	"repository": "github:MarkSuckerberg/txtumblr",
	"version": "1.0.0",
	"private": true,
	"scripts": {
		"deploy": "wrangler deploy src/index.ts",
		"dev": "wrangler dev src/index.ts",
		"test": "vitest",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"gen": "wrangler types"
	},
	"keywords": [
		"tumblr",
		"cloudflare-workers",
		"typescript"
	],
	"author": "Mark Suckerberg <mark@suckerberg.gay> (https://suckerberg.gay)",
	"funding": {
		"type": "ko-fi",
		"url": "https://ko-fi.com/marksuckerberg"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.18.4",
		"@eslint/js": "^10.0.1",
		"@types/node": "^26.1.1",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"prettier": "^3.9.5",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.63.0",
		"vitest": "^4.1.10",
		"wrangler": "^4.110.0"
	},
	"dependencies": {
		"fast-png": "^8.0.0",
		"image-js": "^1.7.0",
		"jpeg-js": "^0.4.4",
		"typeble": "^1.1.1"
	},
	"homepage": "https://github.com/MarkSuckerberg/typeble",
	"bugs": {
		"url": "https://github.com/MarkSuckerberg/typeble/issues"
	}
}
